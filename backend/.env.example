PORT=3000

# Supabase – find these in your project Settings > Database > Connection string
# Use the "URI" format, Transaction mode (port 6543) for serverless/short-lived connections
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase – find in Settings > API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secret for signing tokens (make this a long random string in production)
JWT_SECRET=change-me
